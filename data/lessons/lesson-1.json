    {
      "type": "exercise",
      "id": "questions-order",
      "title": "4. Write the questions in the correct order",
      "instructions": "Write the full question. The final question mark is optional.",
      "items": [
        {
          "id": "1",
          "number": 1,
          "prompt": "do / what / do / you?",
          "input": "text",
          "answer": "What do you do?",
          "acceptedAnswers": [
            "What do you do?",
            "What do you do"
          ],
          "explanation": "Correct question: What do you do? Answer: I’m a chemist. I work for a company that makes perfumes."
        },
        {
          "id": "2",
          "number": 2,
          "prompt": "it / enjoy / you / do?",
          "input": "text",
          "answer": "Do you enjoy it?",
          "acceptedAnswers": [
            "Do you enjoy it?",
            "Do you enjoy it"
          ],
          "explanation": "Correct question: Do you enjoy it? Answer: Yes, it can be fun. We try to create different aromas."
        },
        {
          "id": "3",
          "number": 3,
          "prompt": "the / what / like / are / hours?",
          "input": "text",
          "answer": "What are the hours like?",
          "acceptedAnswers": [
            "What are the hours like?",
            "What are the hours like"
          ],
          "explanation": "Correct question: What are the hours like? Answer: OK. I usually work from eight until four."
        },
        {
          "id": "4",
          "number": 4,
          "prompt": "worked / long / you / have / there / how?",
          "input": "text",
          "answer": "How long have you worked there?",
          "acceptedAnswers": [
            "How long have you worked there?",
            "How long have you worked there"
          ],
          "explanation": "Correct question: How long have you worked there? Answer: About six years now."
        },
        {
          "id": "5",
          "number": 5,
          "prompt": "people / you / with / get on / do / the / work / you / with?",
          "input": "text",
          "answer": "Do you get on with the people you work with?",
          "acceptedAnswers": [
            "Do you get on with the people you work with?",
            "Do you get on with the people you work with"
          ],
          "explanation": "Correct question: Do you get on with the people you work with? Answer: Generally, yes, but we do occasionally have disagreements."
        }
      ]
    },

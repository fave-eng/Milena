    {
      "type": "exercise",
      "id": "job-descriptions",
      "title": "2. Complete the job descriptions",
      "instructions": "Choose the correct profession for each description.",
      "wordBank": [
        "journalist",
        "pilot",
        "nurse",
        "engineer",
        "sales manager",
        "soldier",
        "scientist",
        "police officer"
      ],
      "items": [
        {
          "id": "1",
          "number": 1,
          "prompt": "A ______ works as part of a team and cares for people with health problems. They give medication to patients and help to make a patient comfortable in hospital.",
          "input": "select",
          "options": [
            "journalist",
            "pilot",
            "nurse",
            "engineer",
            "sales manager",
            "soldier",
            "scientist",
            "police officer"
          ],
          "answer": 2,
          "explanation": "The correct job is nurse."
        },
        {
          "id": "2",
          "number": 2,
          "prompt": "A ______ works alone or in a team. They study very hard, do research and experiment both in a laboratory and outdoors.",
          "input": "select",
          "options": [
            "journalist",
            "pilot",
            "nurse",
            "engineer",
            "sales manager",
            "soldier",
            "scientist",
            "police officer"
